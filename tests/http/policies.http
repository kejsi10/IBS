### Policies API Endpoints
### Base URL: https://localhost:7001/api/v1

@baseUrl = https://localhost:7001/api/v1
@contentType = application/json
@tenantId = 00000000-0000-0000-0000-000000000001

### ============================================
### Authentication (get token first)
### ============================================

### Login to get JWT token
# @name loginRequest
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}
X-Tenant-Id: {{tenantId}}

{
  "email": "admin@test.com",
  "password": "Admin123!"
}

### Store the token
@authToken = Bearer {{loginRequest.response.body.accessToken}}

### Variables (update after creating resources)
@clientId = 00000000-0000-0000-0000-000000000002
@carrierId = 00000000-0000-0000-0000-000000000003
@policyId =
@coverageId =
@endorsementId =

### ============================================
### Policy CRUD Operations
### ============================================

### Create a Personal Auto policy
# @name createAutoPolicy
POST {{baseUrl}}/policies
Authorization: {{authToken}}
Content-Type: {{contentType}}

{
  "clientId": "{{clientId}}",
  "carrierId": "{{carrierId}}",
  "lineOfBusiness": "PersonalAuto",
  "policyType": "Personal Auto Insurance",
  "effectiveDate": "2024-01-01",
  "expirationDate": "2025-01-01",
  "billingType": "DirectBill",
  "paymentPlan": "Annual",
  "notes": "New customer auto policy"
}

### Store policy ID
@policyId = {{createAutoPolicy.response.body.id}}

### Create a Homeowners policy
# @name createHomePolicy
POST {{baseUrl}}/policies
Authorization: {{authToken}}
Content-Type: {{contentType}}

{
  "clientId": "{{clientId}}",
  "carrierId": "{{carrierId}}",
  "lineOfBusiness": "Homeowners",
  "policyType": "Homeowners HO-3",
  "effectiveDate": "2024-02-15",
  "expirationDate": "2025-02-15",
  "billingType": "AgencyBill",
  "paymentPlan": "Monthly",
  "notes": "Primary residence coverage"
}

### Create a Commercial General Liability policy
# @name createGLPolicy
POST {{baseUrl}}/policies
Authorization: {{authToken}}
Content-Type: {{contentType}}

{
  "clientId": "{{clientId}}",
  "carrierId": "{{carrierId}}",
  "lineOfBusiness": "GeneralLiability",
  "policyType": "Commercial General Liability",
  "effectiveDate": "2024-03-01",
  "expirationDate": "2025-03-01",
  "billingType": "DirectBill",
  "paymentPlan": "Quarterly"
}

### Create a Workers Compensation policy
POST {{baseUrl}}/policies
Authorization: {{authToken}}
Content-Type: {{contentType}}

{
  "clientId": "{{clientId}}",
  "carrierId": "{{carrierId}}",
  "lineOfBusiness": "WorkersCompensation",
  "policyType": "Workers Compensation",
  "effectiveDate": "2024-04-01",
  "expirationDate": "2025-04-01",
  "billingType": "DirectBill",
