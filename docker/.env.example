# =====================================================
# IBS - Environment Configuration
# =====================================================
# Copy this file to .env and customize for your environment

# -----------------------------------------------------
# SQL Server
# -----------------------------------------------------
SQL_SA_PASSWORD=YourStrong@Passw0rd
SQL_PORT=1433
SQL_DATABASE=IBS

# Connection string for local development:
# Server=localhost,1433;Database=IBS;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True

# -----------------------------------------------------
# Redis (for caching)
# -----------------------------------------------------
REDIS_PORT=6379
REDIS_HOST=localhost

# -----------------------------------------------------
# API Configuration
# -----------------------------------------------------
API_HTTP_PORT=5000
API_HTTPS_PORT=7001

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-here-that-is-at-least-32-characters
JWT_ISSUER=IBS-API
JWT_AUDIENCE=IBS-Web
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# -----------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------
VITE_API_URL=https://localhost:7001
VITE_PORT=5173

# -----------------------------------------------------
# Azure (for production deployment)
# -----------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_KEY_VAULT_URI=

# -----------------------------------------------------
# Serilog Logging
# -----------------------------------------------------
SERILOG_MINIMUM_LEVEL=Information
SERILOG_SEQ_URL=
